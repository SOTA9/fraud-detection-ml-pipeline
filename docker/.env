# ------------------------------
# Kafka configuration
# ------------------------------
BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081

# ------------------------------
# Redis configuration
# ------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# ------------------------------
# PostgreSQL configuration
# ------------------------------
PG_HOST=localhost
PG_USER=fraud
PG_PASSWORD=fraud
PG_DSN=postgresql://fraud:fraud@localhost:5432/fraud

# ------------------------------
# Feast configuration
# ------------------------------
FEAST_REPO_PATH=./feast
FEAST_PG_PASSWORD=fraud

# ------------------------------
# Spark configuration
# ------------------------------
JAVA_HOME=/usr/lib/jvm/java-11-openjdk
CHECKPOINT_DIR=/tmp/fraud_checkpoints

# ------------------------------
# Machine Learning / Model
# ------------------------------
MODEL_PATH=ml/fraud_model.pkl
FRAUD_THRESHOLD=0.85